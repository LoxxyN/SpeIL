{
  "name": "speil",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "linting:check": "npm run format:check && npm run lint",
    "linting:fix": "npm run format && npm run lint:fix",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js, jsx, ts, tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md, mdx}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@monaco-editor/react": "^4.8.0-rc.3",
    "@shikijs/monaco": "^4.0.2",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@gravity-ui/icons": "^2.18.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-fsd-lint": "^1.2.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  }
}
